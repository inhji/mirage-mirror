<article>
  <header>
    <h1><%= @list.title %></h1>
  </header>

  <section class="content html">
    <%= raw Mirage.Markdown.render(@list.content) %>
  </section>

  <h2>Notes</h2>

  <ul>
    <%= for note <- @list.notes do %>
    <li>
      <%= link note.title, to: Routes.admin_note_path(@conn, :show, note) %>
    </li>
    <% end %>
  </ul>
</article>

<span><%= link "Edit", to: Routes.admin_list_path(@conn, :edit, @list) %></span> |
<span><%= link "Back", to: Routes.admin_list_path(@conn, :index) %></span>
