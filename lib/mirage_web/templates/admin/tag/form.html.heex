<.form let={f} for={@changeset} action={@action}>
  <%= if @changeset.action do %>
    <div class="alert alert-danger">
      <p>Oops, something went wrong! Please check the errors below.</p>
    </div>
  <% end %>

  <fieldset>
    <%= label f, :title %>
    <%= text_input f, :title %>
    <%= error_tag f, :title %>
  </fieldset>

  <fieldset>
    <%= label f, :slug %>
    <%= text_input f, :slug, readonly: true %>
    <%= error_tag f, :slug %>
  </fieldset>

  <fieldset>
    <%= label f, :content %>
    <div class="grow-wrap">
      <%= textarea f, :content, rows: 5, onInput: "this.parentNode.dataset.replicatedValue = this.value" %>
    </div>
    <%= error_tag f, :content %>
  </fieldset>

  <fieldset>
    <%= label f, :regex %>
    <%= text_input f, :regex %>
    <%= error_tag f, :regex %>
  </fieldset>

  <div>
    <%= submit "Save" %>
  </div>
</.form>
