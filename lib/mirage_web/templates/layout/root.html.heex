<!DOCTYPE html>
<html lang="en" id="app">
  <head>
    <meta charset="utf-8"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    <link phx-track-static rel="manifest" href={Routes.static_path(@conn, "/manifest.json")} />
    <link phx-track-static rel="icon" href={Routes.static_path(@conn, "/favicon.ico")} />
    <link phx-track-static rel="icon" type="image/png" sizes="16x16" href={Routes.static_path(@conn, "/images/favicon-16x16.png")} />
    <link phx-track-static rel="icon" type="image/png" sizes="32x32" href={Routes.static_path(@conn, "/images/favicon-32x32.png")}>
    <link phx-track-static rel="apple-touch-icon" sizes="180x180" href={Routes.static_path(@conn, "/images/apple-touch-icon.png")}>

    <%= for identity <- @identities do %>
      <link rel={identity.rel} href={identity.value} />
    <% end %>

    <link rel="alternate" type="application/atom+xml" 
      title="Blog Feed for Mirage" 
      href={Routes.feed_path(@conn, :show, "home")} />

    <%= csrf_meta_tag() %>
    <%= live_title_tag assigns[:page_title] || "Mirage", suffix: " · Mirage" %>
    <link phx-track-static rel="stylesheet" href={Routes.static_path(@conn, "/assets/app.css")}/>
  </head>
  <body>
    <div id="wrapper" class="bg-gray-200 dark:bg-gray-800 flex flex-col selection:bg-accent1 selection:text-white">
      <header class="bg-gray-50 dark:bg-gray-700 dark:text-gray-300 shadow-sm">
        <nav class="flex container mx-auto">
          <ul class="flex py-3">
            <li><%= active_link @conn, "ꟿirage", to: Routes.page_path(@conn, :index), class: "p-3 uppercase font-medium" %></li>
          </ul>
          <%= render "_content_menu.html", assigns %>        
          <div class="flex-1"></div>
          <%= render "_misc_menu.html", assigns %>
        </nav>
      </header>
      
      <main id="content" class="container mx-auto px-3 my-10 grow shrink-0">
        <%= @inner_content %>
      </main>

      <footer class="flex-auto border-t dark:border-gray-700">
        <nav class="flex container mx-auto">
          <ul class="flex py-3">
            <li><span class="p-3"><%= @motd %></span></li>
          </ul>
          <div class="flex-1"></div>
          <%= render "_user_menu.html", assigns %>  
        </nav>
      </footer>
    </div>

    <script type="text/javascript">
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.body.classList.add('dark')
      } else {
        document.body.classList.remove('dark')
      }
    </script>
    <script defer phx-track-static type="text/javascript" src={Routes.static_path(@conn, "/assets/app.js")}></script>
  </body>
</html>
