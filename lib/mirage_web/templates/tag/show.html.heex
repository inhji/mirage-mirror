<section>
	<h1>Tagged with “<%= @tag.title %>”</h1>

	<div class="content html">
	  <%= raw @tag.content_html %>
	</div>

	<h2><%= Enum.count(@tag.notes) %> Note(s)</h2>

	<ul>
		<%= for note <- @tag.notes do %>
		<li><%= link note_title(note), to: Routes.note_path(@conn, :show, note) %> <%= datetime_from_now(note.published_at) || "(unpublished)" %></li>
		<% end %>
	</ul>
</section>